# Copy this file to .env and fill in the values before running docker compose.
#
# Generate AIRFLOW_FERNET_KEY:
#   python3 -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
#
# Generate AIRFLOW_SECRET_KEY (any random string):
#   python3 -c "import secrets; print(secrets.token_hex(32))"

AIRFLOW_FERNET_KEY=
AIRFLOW_SECRET_KEY=

# Optional — defaults to 'admin' if not set (change for non-local deployments)
AIRFLOW_ADMIN_PASSWORD=admin
